{
  "colors": {
    "primary":    "#C97B3A",
    "primary-hover": "#A86228",
    "secondary":  "#2E4057",
    "accent":     "#E8C99A",
    "neutral-100": "#F7F3EE",
    "neutral-200": "#EDE6DC",
    "neutral-500": "#9B8F82",
    "neutral-800": "#3D342A",
    "background": "#FAF7F2",
    "surface":    "#FFFFFF",
    "text":       "#1C1512",
    "text-muted": "#7A6E65"
  },
  "fonts": {
    "sans":  "\"DM Sans\", system-ui, sans-serif",
    "serif": "\"Lora\", Georgia, serif",
    "mono":  "\"JetBrains Mono\", monospace"
  },
  "type-scale": {
    "xs":   "0.75rem",
    "sm":   "0.875rem",
    "base": "1rem",
