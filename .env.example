# API keys for this project
# Copy this file to .env and fill in your values. Never commit .env.

# Unsplash API (for placeholder images, optional)
UNSPLASH_ACCESS_KEY=

# OpenAI / Anthropic key (if using AI-assisted copy generation, optional)
ANTHROPIC_API_KEY=

# GitHub token (for pushing via API, optional — can use git CLI instead)
GITHUB_TOKEN=
